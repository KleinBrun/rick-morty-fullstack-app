
PORT=4000

DB_DIALECT=postgres

# Option A:
DB_URL=

# Option B: 
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rickandmorty
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Optional Redis 
REDIS_URL=redis://127.0.0.1:6379

# Frontend allowed to consume the backend
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:4001,http://localhost:4000

# Basic abuse protection
REQUEST_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200