{
    "name": "backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "test": "vitest run",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:migrate:prod": "node dist/db/migrate.js"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^5.1.0",
        "express-rate-limit": "^8.3.2",
        "graphql": "^16.11.0",
        "graphql-http": "^1.22.4",
        "node-cron": "^4.2.1",
        "pg": "^8.16.3",
        "pg-hstore": "^2.3.4",
        "redis": "^5.8.2",
        "sequelize": "^6.37.7"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/node": "^24.7.2",
        "sequelize-cli": "^6.6.3",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vitest": "^4.0.3"
    }
}
